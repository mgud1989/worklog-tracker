TOGGL_API_TOKEN=your_toggl_token

# Tempo + Jira (required for Tempo tools)
TEMPO_API_TOKEN=your_tempo_api_token
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_API_TOKEN=your_jira_api_token
JIRA_EMAIL=your_atlassian_email@example.com
# Optional: basic (default) or bearer
JIRA_AUTH_TYPE=basic
# Optional: Jira custom field id used for Tempo Account (without "customfield_" prefix)
JIRA_TEMPO_ACCOUNT_CUSTOM_FIELD_ID=
